# ─── AI Product Analytics Copilot — Environment Variables ────────────────────
# Copy this file to .env and fill in the values
# DO NOT commit .env to version control

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
DEBUG=true
LOG_LEVEL=INFO

# ── API ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=analytics_copilot

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                  # Leave empty for no password (dev only)
REDIS_DB=0

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── AI / Google Gemini ───────────────────────────────────────────────────────
# Get your FREE API key from: https://aistudio.google.com/apikey
# No credit card needed for the free tier
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash     # Free tier — up to 1,500 requests/day
GEMINI_MAX_TOKENS=8192
GEMINI_TEMPERATURE=0.1             # Low for deterministic analytics

# ── SQL Safety ────────────────────────────────────────────────────────────────
SQL_QUERY_TIMEOUT_MS=30000         # 30 seconds
SQL_MAX_ROWS=10000
SQL_MAX_QUERIES_PER_INVESTIGATION=15

# ── Analytics ─────────────────────────────────────────────────────────────────
DEFAULT_RETENTION_PERIODS=12       # Weeks of retention to track
COHORT_SIZE_MIN=50                 # Min cohort size for significance
ANOMALY_DETECTION_THRESHOLD=2.0   # Standard deviations for anomaly detection

# ── Memory Layer ──────────────────────────────────────────────────────────────
MEMORY_SIMILARITY_THRESHOLD=0.8
MEMORY_MAX_INVESTIGATIONS_STORED=1000

# ── Observability ─────────────────────────────────────────────────────────────
ENABLE_METRICS=true
SENTRY_DSN=                        # Optional: Sentry error tracking DSN
TRACE_SAMPLE_RATE=0.1

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
# Set in frontend/.env.local
NEXT_PUBLIC_API_URL=http://localhost:8000
